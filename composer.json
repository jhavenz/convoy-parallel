{
    "name": "convoy/parallel",
    "description": "Worker process parallelism for Convoy",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.4",
        "convoy/core": "^1.0",
        "react/child-process": "^0.6",
        "react/async": "^4.3",
        "react/event-loop": "^1.5",
        "react/promise": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "Convoy\\Parallel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Convoy\\Parallel\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/convoy-worker"
    ],
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
